<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EdgeBridge.Samples.Avalonia.Views.CameraView">
  <StackPanel Spacing="16">
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="Camera Control" Classes="pageTitle" />
      <Button Grid.Column="1" Content="Add Camera" Command="{Binding AddCommand}" Classes="primary" />
    </Grid>
    <ItemsControl ItemsSource="{Binding Cameras}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Classes="itemCard">
            <Grid ColumnDefinitions="1.2*,1.2*,110,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowDefinitions="Auto,Auto">
              <TextBox Text="{Binding Name}" />
              <TextBox Grid.Column="1" Text="{Binding CameraId}" />
              <TextBlock Grid.Column="2" Text="{Binding StateText}" VerticalAlignment="Center" FontWeight="SemiBold" />
              <Button Grid.Column="3" Content="Start" Command="{Binding StartCommand}" Classes="primary" />
              <Button Grid.Column="4" Content="Stop" Command="{Binding StopCommand}" />
              <Button Grid.Column="5" Content="Refresh" Command="{Binding RefreshCommand}" />
              <Button Grid.Column="6" Content="Remove" Command="{Binding RemoveCommand}" />
              <TextBlock Grid.Row="1" Grid.ColumnSpan="7" Text="{Binding Status}" Foreground="#647086" Margin="0,8,0,0" />
            </Grid>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </StackPanel>
</UserControl>
