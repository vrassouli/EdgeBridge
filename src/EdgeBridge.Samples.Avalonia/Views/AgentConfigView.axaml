<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EdgeBridge.Samples.Avalonia.Views.AgentConfigView">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
      <TextBlock Text="Agent Configuration" Classes="pageTitle" />
      <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}" />
      <Button Grid.Column="2" Content="Apply" Command="{Binding ApplyCommand}" Classes="primary" />
    </Grid>
    <Border Grid.Row="1" Classes="warningCard" IsVisible="{Binding RestartRequired}">
      <TextBlock Text="Saved configuration requires Agent restart before runtime changes take effect." />
    </Border>
    <Grid Grid.Row="2" RowDefinitions="*,Auto" RowSpacing="10">
      <TextBox Text="{Binding ConfigJson}"
               AcceptsReturn="True"
               TextWrapping="NoWrap"
               MinHeight="420"
               FontFamily="Consolas,Menlo,monospace"
               FontSize="13" />
      <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="#647086" />
    </Grid>
  </Grid>
</UserControl>
