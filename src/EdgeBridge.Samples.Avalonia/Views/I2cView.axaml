<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="EdgeBridge.Samples.Avalonia.Views.I2cView">
  <UserControl.Styles>
    <Style Selector="TextBox.i2cNameField">
      <Setter Property="Width" Value="140" />
      <Setter Property="MinWidth" Value="120" />
    </Style>
    <Style Selector="TextBox.i2cNumberInput">
      <Setter Property="Width" Value="104" />
      <Setter Property="MinWidth" Value="104" />
    </Style>
    <Style Selector="ComboBox.i2cFormatInput">
      <Setter Property="Width" Value="116" />
      <Setter Property="MinWidth" Value="116" />
    </Style>
    <Style Selector="TextBox.i2cBytesField">
      <Setter Property="Width" Value="132" />
      <Setter Property="MinWidth" Value="120" />
    </Style>
    <Style Selector="Button.i2cAction">
      <Setter Property="MinWidth" Value="78" />
    </Style>
    <Style Selector="StackPanel.i2cField">
      <Setter Property="Margin" Value="0,0,10,10" />
    </Style>
    <Style Selector="TextBlock.i2cLabel">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#647086" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
  </UserControl.Styles>

  <StackPanel Spacing="16">
    <Grid ColumnDefinitions="*,Auto">
      <TextBlock Text="I2C Register Access" Classes="pageTitle" />
      <Button Grid.Column="1" Content="Add Device" Command="{Binding AddCommand}" Classes="primary" />
    </Grid>
    <ItemsControl ItemsSource="{Binding Devices}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Classes="itemCard">
            <StackPanel>
              <WrapPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Name" Classes="i2cLabel" />
                  <TextBox Text="{Binding Name}"
                           Watermark="Device name"
                           Classes="i2cNameField" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Format" Classes="i2cLabel" />
                  <ComboBox ItemsSource="{Binding ValueFormats}"
                            SelectedItem="{Binding ValueFormat}"
                            Classes="i2cFormatInput" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Bus" Classes="i2cLabel" />
                  <TextBox Text="{Binding BusText}"
                           Classes="i2cNumberInput" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Address" Classes="i2cLabel" />
                  <TextBox Text="{Binding AddressText}"
                           Classes="i2cNumberInput" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Register" Classes="i2cLabel" />
                  <TextBox Text="{Binding RegisterText}"
                           Classes="i2cNumberInput" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Read Length" Classes="i2cLabel" />
                  <TextBox Text="{Binding ReadLengthText}"
                           Classes="i2cNumberInput" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Write Bytes" Classes="i2cLabel" />
                  <TextBox Text="{Binding WriteBytes}"
                           Watermark="0x00 0xFF"
                           Classes="i2cBytesField" />
                </StackPanel>
                <StackPanel Classes="i2cField">
                  <TextBlock Text="Last Read" Classes="i2cLabel" />
                  <TextBox Text="{Binding LastRead}"
                           IsReadOnly="True"
                           Watermark="Last read"
                           Classes="i2cBytesField" />
                </StackPanel>
                <Button Content="Read"
                        Command="{Binding ReadCommand}"
                        Classes="i2cAction"
                        Margin="0,20,10,10"
                        VerticalAlignment="Top" />
                <Button Content="Write"
                        Command="{Binding WriteCommand}"
                        Classes="primary i2cAction"
                        Margin="0,20,10,10"
                        VerticalAlignment="Top" />
                <Button Content="Remove"
                        Command="{Binding RemoveCommand}"
                        Classes="i2cAction"
                        Margin="0,20,10,10"
                        VerticalAlignment="Top" />
              </WrapPanel>
              <TextBlock Text="{Binding Status}" Foreground="#647086" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </StackPanel>
</UserControl>
